PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=quizapp

JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

ADMIN_EMAIL=your_admin_email_here
ADMIN_PASSWORD=your_admin_password_here

GROQ_API_KEY=your_groq_api_key_here

# SMTP Configuration for Email Notifications
# IMPORTANT: For production (especially on Render), use a transactional email service
# like SendGrid, Brevo (formerly Sendinblue), Mailgun, etc. instead of Gmail
# Gmail is often blocked on cloud platforms and has strict sending limits
#
# Example for Brevo:
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your_brevo_smtp_user
# SMTP_PASS=your_brevo_smtp_pass
# SMTP_FROM_EMAIL=your_email@yourdomain.com
#
# Example for SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM_EMAIL=your_email@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
