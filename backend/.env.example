PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=quizapp

JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

ADMIN_EMAIL=your_admin_email_here
ADMIN_PASSWORD=your_admin_password_here

GROQ_API_KEY=your_groq_api_key_here

# Email Notifications Configuration
# Set to false to disable all email notifications completely
EMAIL_ENABLED=true

# SMTP Configuration for Email Notifications
# IMPORTANT: For production (especially on Render), use Brevo (FREE) instead of Gmail!
# Gmail is almost always blocked on Render and has strict sending limits
#
# ⭐⭐⭐ STEP-BY-STEP BREVO SETUP (FREE, 5 MINUTES) ⭐⭐⭐
# 1. Go to https://www.brevo.com/ and sign up for a free account
# 2. Verify your email address
# 3. On the left sidebar, go to "SMTP & API"
# 4. Under "SMTP" tab, you'll see your credentials:
#    - SMTP Server: smtp-relay.brevo.com
#    - Port: 587
#    - Login: [your email you signed up with]
#    - Master password: [click "Generate a new master password" if needed]
# 5. Update the values below!
#
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login_email
SMTP_PASS=your_brevo_master_password
SMTP_FROM_EMAIL=your_brevo_login_email

# Example for SendGrid (alternative):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM_EMAIL=your_email@yourdomain.com
